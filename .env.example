# Neon Postgres connection (auto-populated by the Vercel ↔ Neon Marketplace integration).
# Locally, run: `vercel env pull .env.development.local` to grab a populated copy.
#
# Pooled connection — what app reads use (PgBouncer). Required.
DATABASE_URL=postgres://<user>:<password>@<neon-host>/<db>?sslmode=require
#
# Unpooled / direct connection — required for migrations (DDL, transactions) which
# don't work over PgBouncer. Optional but recommended.
DATABASE_URL_UNPOOLED=postgres://<user>:<password>@<neon-host>/<db>?sslmode=require
